	<queryString>
		<![CDATA[SELECT
     add_property.`p_id` AS add_property_p_id,
     add_property.`property_name` AS add_property_property_name,
     add_property.`location` AS add_property_location,
     add_property.`price` AS add_property_price,
     add_property.`description` AS add_property_description,
     add_property.`image` AS add_property_image,
     add_property.`agentname` AS add_property_agentname,
     add_property.`bedroom` AS add_property_bedroom,
     add_property.`bathroom` AS add_property_bathroom,
     add_property.`square_footage` AS add_property_square_footage,
     add_property.`pool` AS add_property_pool,
     add_property.`gym` AS add_property_gym,
     add_property.`security_system` AS add_property_security_system,
     add_property.`city` AS add_property_city,
     add_property.`zip` AS add_property_zip
FROM
     `add_property` add_property
WHERE p_id = $P{id}]]>
	</queryString>
