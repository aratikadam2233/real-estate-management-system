	<queryString>
		<![CDATA[SELECT
     contactus.`user_id` AS contactus_user_id,
     contactus.`name` AS contactus_name,
     contactus.`subject` AS contactus_subject,
     contactus.`message` AS contactus_message,
     contactus.`email` AS contactus_email
FROM
     `contactus` contactus
WHERE user_id = $P{id}]]>
